# AG Coder — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Required ──────────────────────────────────────────────────────────────────

# Postgres connection string — REQUIRED. The app will not run without it.
DATABASE_URL=postgresql://user:password@localhost:5432/agcoder

# ── LLM (optional — enables live model mode) ──────────────────────────────────
# If both are set, Anthropic takes priority.
# If neither ANTHROPIC_API_KEY nor OPENAI_API_KEY is set, the agent runs in
# deterministic demo mode (no real AI calls, but still produces a real graph
# and event stream).

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# Express session secret — set a long random string in production
SESSION_SECRET=change-me-in-production

# Per-run LLM cost ceiling in USD (optional; default 1.00). The runtime estimates
# each model call's cost and stops the run with budget.cost_exhausted before
# exceeding this. Set to 0 to disable cost gating.
AGENT_MAX_COST_USD=

# GitHub personal access token — only needed for cloning PRIVATE repos in a
# self-hosted / local / CI deployment. On Replit the GitHub integration handles
# this automatically and this can be left unset. Public repos need no token.
GITHUB_TOKEN=

# ── Security (optional) ───────────────────────────────────────────────────────

# Comma-separated list of extra allowed CORS origins (full origins, e.g.
# https://app.example.com). localhost and Replit domains are always allowed.
CORS_ORIGINS=

# If set, mutating endpoints (POST/DELETE on /api/runs...) require this key via
# the `x-api-key` header or `Authorization: Bearer <key>`. Leave unset to keep
# the API open (the default for local/demo use).
AGENT_API_KEY=

# Rate limit for creating/forking runs (per client). Defaults: 10 per 60s.
RUN_RATE_LIMIT_MAX=
RUN_RATE_LIMIT_WINDOW_MS=

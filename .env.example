# AG Coder — environment variables
# Copy this file to .env and fill in your values.
# .env is gitignored and never committed.

# ── Required ──────────────────────────────────────────────────────────────────

# Postgres connection string — REQUIRED. The app will not run without it.
DATABASE_URL=postgresql://user:password@localhost:5432/agcoder

# ── LLM (optional — enables live model mode) ──────────────────────────────────
# If both are set, Anthropic takes priority.
# If neither ANTHROPIC_API_KEY nor OPENAI_API_KEY is set, the agent runs in
# deterministic demo mode (no real AI calls, but still produces a real graph
# and event stream).

OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ── Optional ──────────────────────────────────────────────────────────────────

# Express session secret — set a long random string in production
SESSION_SECRET=change-me-in-production

# GitHub personal access token — only needed for cloning PRIVATE repos in a
# self-hosted / local / CI deployment. On Replit the GitHub integration handles
# this automatically and this can be left unset. Public repos need no token.
GITHUB_TOKEN=
